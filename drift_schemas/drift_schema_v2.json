  "fixed_sql": [
    {
      "name": "accounts",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"accounts\" (\"account_id\" TEXT NOT NULL, \"email\" TEXT NOT NULL, \"access_token\" TEXT NULL, \"refresh_token\" TEXT NULL, \"backend_url\" TEXT NOT NULL, \"created_at\" TEXT NOT NULL, \"last_login_at\" TEXT NULL, PRIMARY KEY (\"account_id\"));"
        }
      ]
    },
    {
      "name": "players",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"players\" (\"player_id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"created_at\" TEXT NOT NULL, \"last_active\" TEXT NOT NULL, \"account_id\" TEXT NULL REFERENCES accounts (account_id) ON DELETE SET NULL, \"avatar_url\" TEXT NULL, PRIMARY KEY (\"player_id\"));"
        }
      ]
    },
    {
      "name": "games",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"games\" (\"game_id\" TEXT NOT NULL, \"game_type\" TEXT NOT NULL, \"config_json\" TEXT NOT NULL, \"start_time\" TEXT NOT NULL, \"end_time\" TEXT NULL, \"winner_competitor_id\" TEXT NULL, \"is_complete\" INTEGER NOT NULL DEFAULT 0, \"game_state_json\" TEXT NULL, PRIMARY KEY (\"game_id\"));"
        }
      ]
    },
    {
      "name": "competitors",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"competitors\" (\"competitor_id\" TEXT NOT NULL, \"game_id\" TEXT NOT NULL REFERENCES games (game_id) ON DELETE CASCADE, \"type\" TEXT NOT NULL, \"name\" TEXT NOT NULL, PRIMARY KEY (\"competitor_id\"));"
        }
      ]
    },
    {
      "name": "competitor_players",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"competitor_players\" (\"competitor_id\" TEXT NOT NULL REFERENCES competitors (competitor_id) ON DELETE CASCADE, \"player_id\" TEXT NOT NULL REFERENCES players (player_id) ON DELETE RESTRICT, \"rotation_position\" INTEGER NOT NULL, PRIMARY KEY (\"competitor_id\", \"player_id\"));"
        }
      ]
    },
    {
      "name": "dart_throws",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"dart_throws\" (\"dart_id\" TEXT NOT NULL, \"game_id\" TEXT NOT NULL REFERENCES games (game_id) ON DELETE CASCADE, \"competitor_id\" TEXT NOT NULL REFERENCES competitors (competitor_id) ON DELETE CASCADE, \"player_id\" TEXT NOT NULL REFERENCES players (player_id) ON DELETE RESTRICT, \"turn_number\" INTEGER NOT NULL, \"dart_number\" INTEGER NOT NULL, \"segment\" TEXT NOT NULL, \"score\" INTEGER NOT NULL, \"x\" REAL NULL, \"y\" REAL NULL, PRIMARY KEY (\"dart_id\"));"
        }
      ]
    },
    {
      "name": "game_events",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"game_events\" (\"event_id\" TEXT NOT NULL, \"game_id\" TEXT NOT NULL REFERENCES games (game_id) ON DELETE CASCADE, \"event_type\" TEXT NOT NULL, \"local_sequence\" INTEGER NOT NULL, \"occurred_at\" TEXT NOT NULL, \"payload_json\" TEXT NOT NULL, \"synced\" INTEGER NOT NULL DEFAULT 0, \"actor_id\" TEXT NOT NULL, \"global_sequence\" INTEGER NULL, \"source\" INTEGER NOT NULL DEFAULT 0, PRIMARY KEY (\"event_id\"), UNIQUE (\"game_id\", \"local_sequence\"));"
        }
      ]
    },
    {
      "name": "sync_queue",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"sync_queue\" (\"operation_id\" TEXT NOT NULL, \"entity_type\" TEXT NOT NULL, \"entity_id\" TEXT NOT NULL, \"operation_type\" TEXT NOT NULL, \"payload_json\" TEXT NOT NULL, \"status\" TEXT NOT NULL DEFAULT 'pending', \"attempt_count\" INTEGER NOT NULL DEFAULT 0, \"created_at\" TEXT NOT NULL, \"last_attempt\" TEXT NULL, \"error_message\" TEXT NULL, PRIMARY KEY (\"operation_id\"));"
        }
      ]
    },
    {
      "name": "game_sessions",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"game_sessions\" (\"session_id\" TEXT NOT NULL, \"game_id\" TEXT NOT NULL REFERENCES games (game_id) ON DELETE CASCADE, \"host_player_id\" TEXT NOT NULL REFERENCES players (player_id) ON DELETE RESTRICT, \"status\" TEXT NOT NULL, \"created_at\" TEXT NOT NULL, \"started_at\" TEXT NULL, \"completed_at\" TEXT NULL, \"current_turn_player_id\" TEXT NULL REFERENCES players (player_id) ON DELETE SET NULL, PRIMARY KEY (\"session_id\"));"
